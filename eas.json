{
  "cli": {
    "version": ">= 16.18.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EAS_BUILD_DISABLE_EXPO_DOCTOR_STEP": "1",
        "NODE_ENV": "production"
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EAS_BUILD_DISABLE_EXPO_DOCTOR_STEP": "1",
        "NODE_ENV": "production"
      },
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EAS_BUILD_DISABLE_EXPO_DOCTOR_STEP": "1",
        "NODE_ENV": "production"
      },
      "ios": {
        "credentialsSource": "local"
      },
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
